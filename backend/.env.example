# ── HanyuStar Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values before running.

# Secret key for JWT signing — change this in production!
SECRET_KEY=hanyustarsupersecretkey987654321

# Database URL (SQLite by default — no setup needed for local dev)
DATABASE_URL=sqlite:///./hanyustar.db

# Groq API Key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
